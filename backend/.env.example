# Green Cast backend environment variables
# Copy to .env and fill in values

# Vercel AI Gateway — powers all AI features (commentary, risk interpretation,
# AI normalization). Create a key in Vercel dashboard -> AI Gateway -> API Keys.
# All AI degrades gracefully (rules-based output still works) if this is absent.
AI_GATEWAY_API_KEY=vck_...

# Model routed through the gateway. Swap provider here without code changes,
# e.g. openai/gpt-4o-mini or anthropic/claude-sonnet-4.6
AI_MODEL=google/gemini-2.5-flash

# SQLite path (defaults to ./greencast.db locally, /tmp on Vercel automatically)
# DATABASE_URL=sqlite:///./greencast.db
